# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Secret Introw API key (scope: affiliate:write). Used server-side for the
# server-to-server affiliate conversion and the Partner Portal auth session.
# Never exposed to the browser (no NEXT_PUBLIC_ prefix).
INTROW_API_KEY=

# Campaign publishable key (pk_aff_...). Safe to expose in the browser; used by
# affiliate.js for the client-side conversion path. Browser conversions are
# additionally gated by the campaign's Origin allowlist.
NEXT_PUBLIC_INTROW_PUBLISHABLE_KEY=
